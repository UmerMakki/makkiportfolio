# Supabase — Dashboard → Settings → API (local: .env.local | Netlify: Environment variables)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-key

# Optional server aliases (runtime on Netlify — use if contact form fails after adding NEXT_PUBLIC_*)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-jwt-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Run migrations: npm run db:migrate (needs DATABASE_URL or SUPABASE_ACCESS_TOKEN)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:6543/postgres
